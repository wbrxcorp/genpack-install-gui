import { Button, VerticalBox, HorizontalBox, ListView, LineEdit, TextEdit, CheckBox, ScrollView, GroupBox, Spinner } from "std-widgets.slint";

// Rust 側と共有するデータ構造。
export struct DiskInfo {
    path: string,
    model: string,
    size: string,
    removable: bool,
}

export struct ImageInfo {
    path: string,
    filename: string,
    size: string,
    arch: string,
    artifact: string,
    banner: string,
    version: string,
    arch-match: bool,
    superfloppy-available: bool,
}

// 確認ダイアログで保留中の破壊的アクション。
enum ConfirmAction {
    none,
    reboot,
    poweroff,
}

// 画面遷移。
export enum Page {
    disk-select,
    image-select,
    options,
    installing,
    done,
    system-info,
    terminal,
}

// 一覧の選択可能な行。
component SelectRow inherits Rectangle {
    in property <bool> selected;
    in property <bool> enabled: true;
    callback clicked;
    height: content.preferred-height + 20px;
    border-radius: 6px;
    border-width: selected ? 2px : 1px;
    border-color: selected ? #3b82f6 : #d0d0d0;
    background: !enabled ? #f2f2f2 : (touch.has-hover ? #eef4ff : white);
    touch := TouchArea {
        enabled: enabled;
        clicked => { root.clicked(); }
    }
    content := HorizontalLayout {
        padding: 12px;
        @children
    }
}

component HeaderBar inherits Rectangle {
    in property <string> title;
    in property <string> hint;   // タイトル右に添える補助テキスト（空なら何も出ない）
    height: 56px;
    background: #1f2937;
    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 12px;
        Text {
            vertical-alignment: center;
            text: title;
            color: white;
            font-size: 20px;
            font-weight: 700;
        }
        // hint はタイトルのすぐ右に添える（右上の ☰ ボタンと干渉させない）。
        Text {
            vertical-alignment: center;
            text: hint;
            color: #9ca3af;
            font-size: 14px;
        }
        Rectangle { }   // スペーサ: 余白を吸って title+hint を左に寄せる
    }
}

export component MainWindow inherits Window {
    title: "genpack installer";
    preferred-width: 900px;
    preferred-height: 600px;
    background: #f7f7f8;

    // ---- 状態 ----
    in-out property <Page> page: Page.disk-select;

    in property <[DiskInfo]> disks;
    in property <[ImageInfo]> images;

    // ---- ターミナル（slint-terminal クレート）----
    // Rust 側が毎フレーム描画済み RGBA を term-frame へ流し込む。キー入力は term-key で
    // PTY へ転送。グリッドサイズは Rust がウィンドウ物理サイズから毎tick算出して追従する。
    in property <image> term-frame;
    callback term-key(string, bool, bool);        // text, ctrl, alt
    callback term-key-released(string);           // KMS用ソフトキーリピートの停止判定に使う

    in-out property <int> selected-disk: -1;
    in-out property <int> selected-image: -1;

    in-out property <string> hostname;
    in-out property <string> timezone;
    in-out property <string> locale;
    in-out property <bool> superfloppy;
    // SSH 公開鍵の引き継ぎ。鍵の有無に応じて Rust が起動時に設定する
    // （鍵あり→チェックオン＋プリフィル、無し→チェックオフ＝入力不要のサイン）。
    in-out property <bool> install-ssh-key: false;
    in-out property <string> ssh-pubkey;

    // 実行中の非同期処理の数。0 より大きい間は busy オーバーレイで操作を遮断する。
    // bool でなくカウンタなのは、複数の処理が重なり得るため
    // （例: 起動直後のディスク一覧とイメージ一覧の同時取得）。
    in-out property <int> busy-count: 0;

    in property <float> progress;            // 0.0 .. 1.0（進捗率が読める操作でのみ意味を持つ）
    in property <int> install-step;          // 現ステップ (1-based)
    in property <int> install-total-steps;   // 総ステップ数
    in property <string> install-step-indicator; // 済み■/未□ の並び（Rust 側で生成）
    in property <string> install-step-message;   // 現ステップの説明
    in property <bool> install-has-progress;     // Progress バーを出すか（進捗率が読めるとき）
    in property <string> install-error;      // 空なら成功
    in property <string> sysinfo-text;

    // debug ビルドか（Rust 側から cfg!(debug_assertions) を流し込む）。
    // Slint には #[cfg] が無いので、開発時のみのメニュー項目はこれで出し分ける。
    in property <bool> debug-build: false;

    // Cargo.toml のバージョン（Rust 側から env!("CARGO_PKG_VERSION") を流し込む）。
    in property <string> app-version;

    // ---- コールバック（Rust 実装） ----
    callback refresh-disks();
    callback refresh-images();
    callback start-install();
    callback do-reboot();
    callback do-poweroff();
    callback do-exit();
    callback load-sysinfo();

    // 選択中イメージの取得ヘルパ。
    property <bool> has-image: selected-image >= 0 && selected-image < images.length;
    property <bool> has-disk: selected-disk >= 0 && selected-disk < disks.length;

    // イメージ選択に伴う派生値の更新は、マウスクリック・矢印キーどちらでも効くよう
    // selected-image の変化に集約する（クリックハンドラに書くとキー操作で漏れるため）。
    changed selected-image => {
        if (selected-image >= 0 && selected-image < images.length) {
            hostname = images[selected-image].artifact;
            superfloppy = false;
        }
    }

    // 補助アクション（システム情報・ターミナル・再起動/電源断）の集約メニュー。
    // 画面下端のボタンから開くドロップダウンは Slint のポップアップ配置調整が
    // 効かず画面外にはみ出したため、上端から下に開く古典的メニューバーにしている。
    // MenuBar は if で囲めないため、無効化はすべて enabled で行う。
    // メニューバー領域は busy オーバーレイ（通常の子要素）で覆えないため、
    // busy 中の無効化も enabled に含める必要がある。
    // 確認待ちのアクション（再起動/電源断はワンクッション置いてから実行する）。
    property <ConfirmAction> confirm-action: ConfirmAction.none;

    property <bool> about-visible: false;

    property <bool> menu-actions-enabled: page != Page.installing && busy-count == 0
        && confirm-action == ConfirmAction.none && !about-visible && !menu-visible;

    // ---- 上部メニュー（キーボードで開ける自作オーバーレイ）----
    // ネイティブ MenuBar はキーボードで開く手段が無いため、F10 / ☰ボタンで開く自作メニューに
    // した。開閉と項目移動は全体を包む root-focus が一手に扱う（フォーカスが常にそこに在り、
    // 閉じた後に一覧操作が死ぬ問題が起きない）。項目は debug/release で出し分ける
    // （reboot/poweroff は release のみ、exit は debug のみ）。
    property <bool> menu-visible: false;
    property <int> menu-index: 0;
    property <[{label: string, id: float}]> menu-items: debug-build
        ? [
            { label: "ℹ " + @tr("System info"), id: 0 },
            { label: "🖥 " + @tr("Terminal"), id: 1 },
            { label: "📦 " + @tr("About…"), id: 4 },
            { label: "🚪 " + @tr("Exit"), id: 5 },
        ]
        : [
            { label: "ℹ " + @tr("System info"), id: 0 },
            { label: "🖥 " + @tr("Terminal"), id: 1 },
            { label: "🔃 " + @tr("Reboot"), id: 2 },
            { label: "🔌 " + @tr("Poweroff"), id: 3 },
            { label: "📦 " + @tr("About…"), id: 4 },
        ];

    // メニュー項目 id → アクション。
    function activate-menu-item(id: float) {
        menu-visible = false;
        if (id == 0) { load-sysinfo(); page = Page.system-info; }
        else if (id == 1) { page = Page.terminal; }
        else if (id == 2) { confirm-action = ConfirmAction.reboot; }
        else if (id == 3) { confirm-action = ConfirmAction.poweroff; }
        else if (id == 4) { about-visible = true; }
        else if (id == 5) { do-exit(); }
    }

    // 画面・モーダル状態が変わるたびに root-focus へフォーカスを戻す。
    // これでモーダルを開いた瞬間からキー操作が root-focus に届き（LineEdit にフォーカスが
    // 残っていても奪い返す）、閉じた後もフォーカスが宙に浮かず一覧操作が復帰する。
    changed page => { root-focus.focus(); }
    changed menu-visible => { root-focus.focus(); }
    changed about-visible => { root-focus.focus(); }
    changed confirm-action => { root-focus.focus(); }

    // 全ページを包む単一の FocusScope。一覧の矢印操作もメニューの開閉/操作もここで扱う。
    // フォーカスは常にここに在るため、テキスト入力欄（オプション画面）は Tab で入って使う。
    root-focus := FocusScope {
        init => { root-focus.focus(); }
        key-pressed(event) => {
            // --- メニューが開いている間 ---
            if (menu-visible) {
                if (event.text == Key.Escape) { menu-visible = false; return accept; }
                if (event.text == Key.UpArrow) {
                    if (menu-index > 0) { menu-index -= 1; }
                    return accept;
                }
                if (event.text == Key.DownArrow) {
                    if (menu-index < menu-items.length - 1) { menu-index += 1; }
                    return accept;
                }
                if (event.text == Key.Return) {
                    activate-menu-item(menu-items[menu-index].id);
                    return accept;
                }
                return accept; // 開いている間は他キーを吸う
            }
            // --- About ダイアログ（Enter/Esc で閉じる）---
            if (about-visible) {
                if (event.text == Key.Escape || event.text == Key.Return) { about-visible = false; }
                return accept;
            }
            // --- 確認ダイアログ（Enter=実行 / Esc=取消）---
            if (confirm-action != ConfirmAction.none) {
                if (event.text == Key.Escape) { confirm-action = ConfirmAction.none; return accept; }
                if (event.text == Key.Return) {
                    if (confirm-action == ConfirmAction.reboot) { do-reboot(); } else { do-poweroff(); }
                    confirm-action = ConfirmAction.none;
                    return accept;
                }
                return accept; // 開いている間は他キーを吸う
            }
            // --- F10 でメニューを開く ---
            if (event.text == Key.F10 && menu-actions-enabled) {
                menu-index = 0;
                menu-visible = true;
                return accept;
            }
            // --- ターミナル: 全キーを PTY へ転送 ---
            // メニュー/ダイアログ判定（上記）を通り抜けた通常時のみ。F10 は上で先に拾うので
            // メニューが「端末から抜ける」脱出口になる（Esc は VT シーケンスなので奪わない）。
            if (page == Page.terminal) {
                root.term-key(event.text, event.modifiers.control, event.modifiers.alt);
                return accept;
            }
            // --- ディスク選択のキーボード操作 ---
            if (page == Page.disk-select) {
                if (event.text == Key.UpArrow) { if (selected-disk > 0) { selected-disk -= 1; } return accept; }
                if (event.text == Key.DownArrow) { if (selected-disk < disks.length - 1) { selected-disk += 1; } return accept; }
                if (event.text == Key.Home) { if (disks.length > 0) { selected-disk = 0; } return accept; }
                if (event.text == Key.End) { if (disks.length > 0) { selected-disk = disks.length - 1; } return accept; }
                if (event.text == Key.Return) { if (has-disk) { page = Page.image-select; } return accept; }
            }
            // --- イメージ選択のキーボード操作 ---
            if (page == Page.image-select) {
                if (event.text == Key.UpArrow) { if (selected-image > 0) { selected-image -= 1; } return accept; }
                if (event.text == Key.DownArrow) { if (selected-image < images.length - 1) { selected-image += 1; } return accept; }
                if (event.text == Key.Home) { if (images.length > 0) { selected-image = 0; } return accept; }
                if (event.text == Key.End) { if (images.length > 0) { selected-image = images.length - 1; } return accept; }
                if (event.text == Key.Return) { if (has-image) { page = Page.options; } return accept; }
            }
            return reject;
        }
        // 端末のソフトキーリピート停止用（KMS はキーリピートを合成しないため Rust 側で補う）。
        key-released(event) => {
            if (page == Page.terminal) { root.term-key-released(event.text); return accept; }
            return reject;
        }
        VerticalLayout {
        // ===================== ディスク選択 =====================
        if page == Page.disk-select: VerticalLayout {
            HeaderBar { title: @tr("Select installation target disk"); }
            VerticalBox {
                padding: 20px;
                spacing: 12px;
                Text {
                    text: @tr("Choose the disk to install to. All data on it will be erased.");
                    color: #b91c1c;
                }
                // 一覧のキーボード操作（矢印/Enter）は全体を包む root-focus で扱う。
                ListView {
                    vertical-stretch: 1;
                    for disk[idx] in disks: SelectRow {
                        selected: idx == selected-disk;
                        clicked => { selected-disk = idx; }
                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: disk.path + "  (" + disk.size + ")"
                                    + (disk.removable ? "  ⏏ " + @tr("removable") : "");
                                font-size: 16px;
                                font-weight: 600;
                            }
                            Text { text: disk.model; color: #6b7280; }
                        }
                    }
                }
                HorizontalBox {
                    alignment: space-between;
                    Button {
                        text: "🔄 " + @tr("Refresh");
                        clicked => { refresh-disks(); }
                    }
                    Button {
                        text: @tr("Next") + " ➡";
                        enabled: has-disk;
                        clicked => { page = Page.image-select; }
                    }
                }
            }
        }

        // ===================== イメージ選択 =====================
        if page == Page.image-select: VerticalLayout {
            HeaderBar { title: @tr("Select image to install"); }
            VerticalBox {
                padding: 20px;
                spacing: 12px;
                // 一覧のキーボード操作（矢印/Enter）は全体を包む root-focus で扱う。
                ListView {
                    vertical-stretch: 1;
                    for img[idx] in images: SelectRow {
                        selected: idx == selected-image;
                        // arch 不一致でも選択・インストールは可能にする（別アーキ向けに
                        // インストールする用途があるため）。注意喚起は下の警告のみ。
                        // 派生値(hostname 等)の更新は changed selected-image に集約。
                        clicked => { selected-image = idx; }
                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: img.filename + "  (" + img.size + ")";
                                font-size: 16px;
                                font-weight: 600;
                            }
                            Text {
                                text: "arch: " + img.arch + "   artifact: " + img.artifact
                                    + (img.version != "" ? "   " + img.version : "");
                                color: #6b7280;
                            }
                            if !img.arch-match: Text {
                                text: "⚠ " + @tr("Architecture differs from this machine (installing anyway)");
                                color: #b45309;
                            }
                        }
                    }
                }
                HorizontalBox {
                    alignment: space-between;
                    Button {
                        text: "⬅ " + @tr("Back");
                        clicked => { page = Page.disk-select; }
                    }
                    HorizontalBox {
                        Button {
                            text: "🔄 " + @tr("Refresh");
                            clicked => { refresh-images(); }
                        }
                        Button {
                            text: @tr("Next") + " ➡";
                            enabled: has-image;
                            clicked => { page = Page.options; }
                        }
                    }
                }
            }
        }

        // ===================== インストールオプション =====================
        if page == Page.options: VerticalLayout {
            HeaderBar { title: @tr("Installation options"); }
            ScrollView {
                VerticalBox {
                    alignment: start;   // 余白を下端に寄せ、各グループを自然な高さに詰める
                    padding: 20px;
                    spacing: 16px;

                    GroupBox {
                        title: @tr("Summary");
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: @tr("Disk") + ": " + (has-disk ? disks[selected-disk].path : ""); }
                            Text { text: @tr("Image") + ": " + (has-image ? images[selected-image].filename : ""); }
                        }
                    }

                    GroupBox {
                        title: @tr("Disk format");
                        VerticalLayout {
                            spacing: 6px;
                            CheckBox {
                                text: @tr("Superfloppy mode (format whole disk as FAT32, no partition table)");
                                checked <=> superfloppy;
                                enabled: has-image && images[selected-image].superfloppy-available;
                            }
                            if has-image && !images[selected-image].superfloppy-available: Text {
                                text: @tr("Unavailable: system image is 4GiB or larger");
                                color: #6b7280;
                                font-size: 12px;
                            }
                        }
                    }

                    GroupBox {
                        title: @tr("System settings");
                        VerticalLayout {
                            spacing: 10px;
                            HorizontalLayout {
                                spacing: 12px;
                                Text { width: 120px; vertical-alignment: center; text: @tr("Hostname"); }
                                LineEdit { text <=> hostname; placeholder-text: @tr("(optional)"); }
                            }
                            HorizontalLayout {
                                spacing: 12px;
                                Text { width: 120px; vertical-alignment: center; text: @tr("Timezone"); }
                                LineEdit { text <=> timezone; }
                            }
                            HorizontalLayout {
                                spacing: 12px;
                                Text { width: 120px; vertical-alignment: center; text: @tr("Locale"); }
                                LineEdit { text <=> locale; }
                            }
                        }
                    }

                    GroupBox {
                        title: @tr("SSH access");
                        VerticalLayout {
                            spacing: 6px;
                            CheckBox {
                                text: @tr("Install SSH key(s) for root (carried over from this installer)");
                                checked <=> install-ssh-key;
                            }
                            TextEdit {
                                text <=> ssh-pubkey;
                                enabled: install-ssh-key;   // オフでグレー化
                                height: 90px;
                            }
                            Text {
                                text: @tr("These keys can log in as root on the installed system.");
                                color: #6b7280;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
            HorizontalBox {
                padding: 20px;
                alignment: space-between;
                Button {
                    text: "⬅ " + @tr("Back");
                    clicked => { page = Page.image-select; }
                }
                Button {
                    text: @tr("Install");
                    primary: true;
                    clicked => { start-install(); }
                }
            }
        }

        // ===================== インストール中 =====================
        if page == Page.installing: VerticalLayout {
            HeaderBar { title: @tr("Installing"); }
            VerticalBox {
                padding: 40px;
                spacing: 20px;
                alignment: center;
                Text {
                    text: @tr("Installing… Do not remove the disk or power off.");
                    font-size: 18px;
                    horizontal-alignment: center;
                }

                // ステップ表示: 「Step X/N ■■□□…」＋ 現ステップの説明。
                // 進捗率の読めない操作（parted/mkfs 等）はここまでで、Progress バーは出さない。
                HorizontalLayout {
                    alignment: center;
                    spacing: 12px;
                    Text {
                        text: @tr("Step {}/{}", install-step, install-total-steps);
                        font-size: 16px;
                        vertical-alignment: center;
                        color: #374151;
                    }
                    Text {
                        text: install-step-indicator;
                        font-size: 16px;
                        vertical-alignment: center;
                        color: #3b82f6;
                    }
                }
                Text {
                    text: install-step-message + "…";
                    horizontal-alignment: center;
                    font-size: 15px;
                    color: #111827;
                }

                // 進捗率の分かる操作（システムイメージのコピー）のときだけ Progress バーを出す。
                if install-has-progress: VerticalLayout {
                    spacing: 8px;
                    Rectangle {
                        height: 24px;
                        border-radius: 12px;
                        background: #e5e7eb;
                        Rectangle {
                            x: 0;
                            width: parent.width * progress;
                            height: parent.height;
                            border-radius: 12px;
                            background: #3b82f6;
                        }
                    }
                    Text {
                        text: Math.round(progress * 100) + "%";
                        horizontal-alignment: center;
                        color: #374151;
                    }
                }
            }
        }

        // ===================== 完了 =====================
        if page == Page.done: VerticalLayout {
            HeaderBar { title: @tr("Installation complete"); }
            VerticalBox {
                padding: 40px;
                spacing: 20px;
                alignment: center;
                if install-error == "": Text {
                    text: @tr("Installation completed successfully.");
                    font-size: 20px;
                    horizontal-alignment: center;
                }
                if install-error != "": VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: @tr("Installation failed:");
                        font-size: 20px;
                        color: #b91c1c;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: install-error;
                        horizontal-alignment: center;
                        color: #b91c1c;
                        wrap: word-wrap;
                    }
                }
                HorizontalBox {
                    alignment: center;
                    spacing: 12px;
                    if install-error != "": Button {
                        text: "⬅ " + @tr("Back");
                        clicked => { page = Page.options; }
                    }
                    if install-error == "": Button {
                        text: @tr("Reboot");
                        primary: true;
                        clicked => { do-reboot(); }
                    }
                }
            }
        }

        // ===================== システム情報 =====================
        if page == Page.system-info: VerticalLayout {
            HeaderBar { title: @tr("System information"); }
            VerticalBox {
                padding: 20px;
                ScrollView {
                    vertical-stretch: 1;
                    Text {
                        text: sysinfo-text;
                        font-family: "monospace";
                        font-size: 14px;
                    }
                }
                HorizontalBox {
                    alignment: start;
                    Button {
                        text: "⬅ " + @tr("Back");
                        clicked => { page = Page.disk-select; }
                    }
                }
            }
        }

        // ===================== ターミナル（slint-terminal）=====================
        // キー入力は root-focus が term-key で PTY へ転送。シェルを `exit` すると Rust 側
        // on_exit がページを戻す（F10 メニューからの離脱も可）。
        if page == Page.terminal: VerticalLayout {
            HeaderBar {
                title: @tr("Terminal");
                hint: @tr("exit or Ctrl-D to quit");
            }
            Rectangle {
                background: black;
                Image {
                    source: root.term-frame;
                    image-rendering: pixelated;   // テキストなので 1:1、平滑化しない
                    width: 100%;
                    height: 100%;
                }
            }
        }
    }
    }

    // ☰ メニューを開くトリガ（マウス用。キーボードは F10）。上部バー右端に浮かせる。
    if menu-actions-enabled: Rectangle {
        x: parent.width - self.width - 8px;
        y: 8px;
        width: 92px;
        height: 40px;
        border-radius: 6px;
        background: menu-touch.has-hover ? #374151 : #2b3648;
        Text {
            text: "☰ F10";
            color: white;
            vertical-alignment: center;
            horizontal-alignment: center;
            font-size: 15px;
        }
        menu-touch := TouchArea {
            clicked => { menu-index = 0; menu-visible = true; }
        }
    }

    // ===================== メニュー（自作オーバーレイ）=====================
    if menu-visible: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000060;
        TouchArea { clicked => { menu-visible = false; } }   // 外側クリックで閉じる
        Rectangle {
            x: parent.width - self.width - 8px;
            y: 8px;
            width: 280px;
            height: menu-card-layout.preferred-height;
            background: white;
            border-radius: 8px;
            border-width: 1px;
            border-color: #d0d0d0;
            menu-card-layout := VerticalLayout {
                padding: 6px;
                for item[idx] in menu-items: Rectangle {
                    height: 42px;
                    border-radius: 6px;
                    background: (idx == menu-index || row-touch.has-hover) ? #eef4ff : white;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        Text {
                            text: item.label;
                            vertical-alignment: center;
                            font-size: 16px;
                        }
                    }
                    row-touch := TouchArea {
                        clicked => { activate-menu-item(item.id); }
                    }
                }
            }
        }
    }

    // ===================== About ダイアログ =====================
    // Slint の Royalty-Free ライセンスが求める帰属表示（Made with Slint）を兼ねる。
    if about-visible: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000060;
        TouchArea { }   // 背面への操作を遮断
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 460px;
            height: about-layout.preferred-height;
            background: white;
            border-radius: 8px;
            border-width: 1px;
            border-color: #d0d0d0;
            about-layout := VerticalBox {
                padding: 24px;
                spacing: 8px;
                Text {
                    text: "genpack installer";
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: "genpack-install-gui " + app-version;
                    horizontal-alignment: center;
                    color: #6b7280;
                }
                Text {
                    text: "© 2026 Walbrix Corporation";
                    horizontal-alignment: center;
                }
                Text {
                    text: "https://github.com/wbrxcorp/genpack-install-gui";
                    horizontal-alignment: center;
                    color: #3b82f6;
                }
                Text {
                    text: "Made with Slint (https://slint.dev)";
                    horizontal-alignment: center;
                }
                HorizontalBox {
                    alignment: center;
                    Button {
                        text: @tr("Close");
                        clicked => { about-visible = false; }
                    }
                }
            }
        }
    }

    // ===================== 確認ダイアログ =====================
    // 再起動/電源断のワンクッション。busy オーバーレイと同じ全画面遮断方式。
    if confirm-action != ConfirmAction.none: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000060;
        TouchArea { }   // 背面への操作を遮断
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 420px;
            height: dialog-layout.preferred-height;
            background: white;
            border-radius: 8px;
            border-width: 1px;
            border-color: #d0d0d0;
            dialog-layout := VerticalBox {
                padding: 24px;
                spacing: 16px;
                Text {
                    text: confirm-action == ConfirmAction.reboot
                        ? @tr("Reboot the machine?")
                        : @tr("Power off the machine?");
                    font-size: 16px;
                    wrap: word-wrap;
                }
                HorizontalBox {
                    alignment: end;
                    spacing: 12px;
                    Button {
                        text: @tr("Cancel");
                        clicked => { confirm-action = ConfirmAction.none; }
                    }
                    Button {
                        text: confirm-action == ConfirmAction.reboot
                            ? "🔃 " + @tr("Reboot")
                            : "🔌 " + @tr("Poweroff");
                        primary: true;
                        clicked => {
                            if (confirm-action == ConfirmAction.reboot) {
                                do-reboot();
                            } else {
                                do-poweroff();
                            }
                            confirm-action = ConfirmAction.none;
                        }
                    }
                }
            }
        }
    }

    // ===================== busy オーバーレイ =====================
    // 時間のかかる処理（lsblk 等）の間、全画面を半透明で覆って下の UI への
    // ポインタ入力を遮断し、スピナーを表示する。後に書かれた要素が前面に
    // 描画されるため、必ずコンポーネントの最後に置くこと。
    if busy-count > 0: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000040;
        TouchArea { }   // クリックを吸収してモーダルにする
        Spinner {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 64px;
            height: 64px;
            indeterminate: true;
        }
    }
}
